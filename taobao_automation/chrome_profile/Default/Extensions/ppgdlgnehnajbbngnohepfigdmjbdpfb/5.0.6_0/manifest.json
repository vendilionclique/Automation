   "permissions": [ "activeTab", "alarms", "background", "cookies", "declarativeContent", "declarativeNetRequest", "declarativeNetRequestFeedback", "declarativeNetRequestWithHostAccess", "downloads", "notifications", "offscreen", "scripting", "sessions", "storage", "tabs", "userScripts", "unlimitedStorage", "webNavigation", "webRequest" ],
