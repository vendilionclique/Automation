# Copy this file to local/midscene-computer.env and fill in local-only secrets.
# Do not commit local/midscene-computer.env.

# OpenAI-compatible VLM endpoint used by Midscene for visual grounding.
# Default: paid high-speed Zhipu GLM-4.6V-FlashX for Midscene grounding.
# Kimi/Moonshot was abandoned for this workflow and is not the mainline.
# GLM-5V-Turbo is reserved only for later A/B evaluation.
export MIDSCENE_MODEL_NAME="glm-4.6v-flashx"
export MIDSCENE_MODEL_API_KEY=""
export MIDSCENE_MODEL_BASE_URL="https://open.bigmodel.cn/api/paas/v4"

# Pick the model family that matches the vendor/model.
# Common Midscene families include qwen2.5-vl, qwen3-vl, doubao-vision,
# gemini, glm-v, auto-glm, vlm-ui-tars, vlm-ui-tars-doubao,
# vlm-ui-tars-doubao-1.5.
export MIDSCENE_MODEL_FAMILY="glm-v"

export MIDSCENE_MODEL_REASONING_ENABLED="false"
export MIDSCENE_MODEL_TEMPERATURE="0"

# Keep Midscene artifacts local and quiet. Leave MIDSCENE_RUN_DIR empty to let
# local/start_midscene_computer_mcp.sh derive it from the repository root.
export MIDSCENE_RUN_DIR=""
export MIDSCENE_REPORT_QUIET="true"
